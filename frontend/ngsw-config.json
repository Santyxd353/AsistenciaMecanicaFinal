{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/**",
          "/*.(svg|cur|jpg|jpeg|png|webp|avif|gif|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-read-cache",
      "urls": [
        "http://localhost:8000/api/v1/kpis/**",
        "http://localhost:8000/api/v1/talleres/**",
        "http://localhost:8000/api/v1/solicitudes/**",
        "http://localhost:8000/api/v1/tracking/**"
      ],
      "cacheConfig": {
        "strategy": "freshness",
        "maxSize": 100,
        "maxAge": "6h",
        "timeout": "5s"
      }
    }
  ]
}
