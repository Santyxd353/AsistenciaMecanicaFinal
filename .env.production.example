# Copiar este archivo como .env en la VM de produccion.
# No subir el .env real a GitHub.

# Dominio publico.
# Para probar solo con IP publica usa:
# APP_DOMAIN=:80
# Cuando tengas dominio apuntando a la VM usa:
# APP_DOMAIN=rutasos.tudominio.com
APP_DOMAIN=:80
FRONTEND_BASE_URL=http://TU_IP_PUBLICA
CORS_ALLOWED_ORIGINS=http://TU_IP_PUBLICA

# PostgreSQL interno del docker-compose.prod.yml.
POSTGRES_USER=rutasos
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_LARGO
POSTGRES_DB=rutasos
DATABASE_URL=postgresql://rutasos:CAMBIAR_PASSWORD_LARGO@db:5432/rutasos

# Seguridad JWT. Generar uno nuevo para produccion.
SECRET_KEY=CAMBIAR_SECRET_KEY_LARGO
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# IA opcional. Dejar vacio si no se usara.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Audio / IA local.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_LANGUAGE=es
WHISPER_BEAM_SIZE=5
MAX_AUDIO_MB=25
PIPER_VOICE_NAME=es_ES-carlfm-x_low
PIPER_AUTO_DOWNLOAD=true

# Push notifications.
# App ID publico de OneSignal usado por la APK RutaSOS.
ONESIGNAL_APP_ID=c14820b1-68ee-433d-9d6d-22c355daad2c
# REST API key privada. Debe configurarse en la VM real; no dejar vacia.
ONESIGNAL_REST_API_KEY=
ENABLE_LEGACY_FCM_FALLBACK=false
